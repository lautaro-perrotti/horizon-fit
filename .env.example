# Copiá este archivo a .env y ajustá por entorno.
#
# WP_PUBLIC_HOST: host:puerto público de WordPress, usado por WP-CLI y cron
# (cuando no hay HTTP_HOST del navegador) para generar la cache de
# productos/imágenes con el dominio correcto.
#
#   Local:  localhost:8089   (es el default si no creás .env)
#   VPS:    187.77.28.61:8089
#
WP_PUBLIC_HOST=localhost:8089
